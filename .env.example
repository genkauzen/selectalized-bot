# ════════════════════════════════════════════════════════════
#  Selectalized Bot — конфигурация
#  Скопируйте этот файл в .env и заполните значения
# ════════════════════════════════════════════════════════════


# ── Telegram ─────────────────────────────────────────────────

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Включить SOCKS5-прокси для Telegram (true / false)
TG_PROXY_USE=false

# URL прокси — только если TG_PROXY_USE=true
# Формат: socks5://user:pass@host:port
TG_PROXY_URL=

# ID группы/супергруппы, в которой работает бот
# Узнать: переслать сообщение из группы боту @userinfobot
GROUP_ID=

# ID топика для общих логов (ошибки, добавление аккаунтов, найденные IP)
TOPIC_ID_LOGS=

# ID топика для вывода текущего процесса (создание/удаление IP в реальном времени)
TOPIC_ID_LIVE=


# ── Selectel ─────────────────────────────────────────────────

# Включить SOCKS5-прокси для запросов к Selectel API (true / false)
SELECTEL_PROXY_USE=false

# URL прокси — только если SELECTEL_PROXY_USE=true
SELECTEL_PROXY_URL=

# Название для идентификации (не используется в API напрямую)
SELECTEL_VM_NAME=selectalized-vm

# Регионы для перебора через запятую
# Москва (ru-1, ru-2) / Санкт-Петербург (ru-3)
# По умолчанию: ru-2,ru-3
SELECTEL_VM_REGION=ru-2,ru-3

# Сколько аккаунтов работают одновременно (default: 2, min: 1)
SELECTEL_ATMOMENT_ACC=2

# Минимальный баланс аккаунта в рублях для участия в переборе
# 0 = без ограничения
SELECTEL_MINIMUM_RUBLES=0
